{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "ChangeMe Full Stack",
      "configurations": ["ChangeMe Backend", "ChangeMe Frontend"]
    }
  ],
  "configurations": [
    {
      "name": "ChangeMe Backend",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "changeme-backend: build solution",
      "program": "${workspaceFolder}/src/ChangeMe.Backend/src/ChangeMe.Backend.Web/bin/Debug/net10.0/ChangeMe.Backend.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/ChangeMe.Backend/src/ChangeMe.Backend.Web",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:5001"
      }
    },
    {
      "name": "ChangeMe Frontend",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start -- --host 0.0.0.0 --port 4200",
      "cwd": "${workspaceFolder}/src/ChangeMe.Frontend"
    }
  ]
}
