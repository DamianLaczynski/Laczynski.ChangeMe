{
  "$schema": "http://json.schemastore.org/template",
  "author": "Damian Łączyński",
  "classifications": ["Web", "Angular", "ASP.NET", "FullStack"],
  "identity": "ChangeMe.Template",
  "groupIdentity": "ChangeMe",
  "name": "ChangeMe Full Stack Starter",
  "shortName": "changeme",
  "description": "Full-stack starter with Angular frontend, layered ASP.NET backend, PostgreSQL, Docker Compose, and tests.",
  "sourceName": "ChangeMe",
  "preferNameDirectory": true,
  "defaultName": "IssuesDemo",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "nameLower": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "lowerCaseInvariant",
      "replaces": "changeme"
    }
  },
  "sources": [
    {
      "exclude": [
        ".git/**",
        ".template.config/**",
        ".template-test-output/**",
        ".tmp-template-inspect/**",
        "template-pack/**",
        "**/.vs/**",
        "**/.angular/**",
        "**/node_modules/**",
        "**/dist/**",
        "**/bin/**",
        "**/obj/**",
        "**/TestResults/**",
        "**/logs/**",
        "**/*.log",
        "**/devserver.out.log",
        "**/devserver.err.log"
      ]
    }
  ],
  "primaryOutputs": [
    {
      "path": "src/ChangeMe.Backend/ChangeMe.Backend.sln"
    },
    {
      "path": "src/ChangeMe.Frontend/package.json"
    }
  ]
}
